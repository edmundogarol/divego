{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@tests": ["app/tests/*"],
      "@assets/*": ["app/components/*"],
      "@components/*": ["app/components/*"],
      "@modules/*": ["app/modules/*"],
    },
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
